# AI Resume Analyzer - Environment Configuration
# Copy this file to .env and modify values as needed

# Flask Environment
FLASK_ENV=development
FLASK_DEBUG=1

# Server Configuration
FLASK_HOST=0.0.0.0
FLASK_PORT=5000

# File Upload Settings
MAX_UPLOAD_SIZE=16
UPLOAD_DIR=uploads

# ATS Scoring Configuration
# Weights must sum to 1.0
ATS_KEYWORD_WEIGHT=0.30
ATS_SKILLS_WEIGHT=0.25
ATS_SENIORITY_WEIGHT=0.15
ATS_EDUCATION_WEIGHT=0.10
ATS_EXPERIENCE_WEIGHT=0.10
ATS_FORMAT_WEIGHT=0.10

# Security
SECRET_KEY=your-secret-key-here-change-in-production

# Logging
LOG_LEVEL=INFO
LOG_FILE=logs/resume_analyzer.log
